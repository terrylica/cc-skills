__preflight_timing_mark_phase_start_using_EPOCHREALTIME
echo "→ Running wildcard-matcher audit (PreToolUse + PostToolUse hooks)..."
if ! mise run audit-pretooluse-and-posttooluse-hooks-for-wildcard-matcher-star-or-null-which-cold-starts-bun-on-every-tool-call-causing-12-17ms-cpu-or-latency-waste-per-non-meaningful-invocation >/tmp/wildcard-matcher-audit.log 2>&1; then
