fi
__preflight_timing_report_phase_elapsed_milliseconds "Check 4c: hook registration sanity"

# Check 4d: Chronicle slicing regression suite (37 assertions). Verifies the
# release:chronicle phase picks the right JSONLs across boundary mtimes,
# subagent recursion, brotli decompression, and visibility-gate parsing.
__preflight_timing_mark_phase_start_using_EPOCHREALTIME
