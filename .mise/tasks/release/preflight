__preflight_timing_mark_phase_start_using_EPOCHREALTIME
echo "→ Running pueue-wrap-guard last-PreToolUse-entry ordering audit..."
if ! mise run audit-pretooluse-pueue-wrap-guard-is-last-pretooluse-entry-in-hooks-json-to-mitigate-github-15897-multi-hook-updatedInput-aggregation-last-writer-wins-bug >/tmp/pueue-wrap-guard-ordering-audit.log 2>&1; then
    echo "  ✗ Pueue-wrap-guard ordering audit FAILED — see /tmp/pueue-wrap-guard-ordering-audit.log"
