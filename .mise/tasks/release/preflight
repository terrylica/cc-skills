__preflight_timing_mark_phase_start_using_EPOCHREALTIME
echo "→ Running INVERSE PreToolUse schema-correctness audit (non-PreToolUse hooks)..."
if ! mise run audit-non-pretooluse-hooks-for-accidental-use-of-pretooluse-only-hookSpecificOutput-permissionDecision-field-which-silently-fails-to-block-on-posttooluse-stop-userpromptsubmit-sessionstart-sessionend-events >/tmp/inverse-pretooluse-schema-audit.log 2>&1; then
