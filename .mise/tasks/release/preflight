# Loose-coupled defensive grep — see iter-70 hardening note above.
HOOK_TESTS_PASSED=$( { grep -oE 'Test files PASSED:[[:space:]]+[0-9]+' /tmp/hook-regression-test.log || true; } | head -1 | awk '{print $NF}' || echo 0)
