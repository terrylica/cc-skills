if ! mise run release:test-chronicle-slicing >/tmp/chronicle-test.log 2>&1; then
    echo "  ✗ Chronicle slicing test FAILED — see /tmp/chronicle-test.log"
    tail -20 /tmp/chronicle-test.log
    exit 1
fi
# Loose-coupled defensive grep — see iter-70 "brittle-banner-grep
# hardening" lesson in docs/HOOKS.md. The `|| true` swallows pipefail
# when the audit banner phrasing evolves; `|| echo 0` provides a safe
# fallback if the downstream awk pipeline fails. Without these defenses,
# a future banner rename would silently abort the gate with no
# actionable diagnostic (exactly what hit iter-69 Check 4j).
PASS=$( { grep -oE '[0-9]+ passed' /tmp/chronicle-test.log || true; } | head -1 | awk '{print $1}' || echo 0)
echo "  ✓ Chronicle slicing: ${PASS:-0} assertions passed"
__preflight_timing_report_phase_elapsed_milliseconds "Check 4d: chronicle slicing regression suite (37 assertions)"

# Check 4e: Marketplace-wide hook regression suite. Iter-51 wire-up of
