{
  "description": "GitNexus knowledge graph — MCP redirect, staleness detection, session-end reindex reminder",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "readMcpResource|useMcpTool",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-mcp-redirect.ts",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-staleness-detector.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/stop-reindex-reminder.ts",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
