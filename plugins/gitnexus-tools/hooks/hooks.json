{
  "description": "GitNexus knowledge graph — CLI reminder, staleness detection, session-end reindex reminder",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Glob|Grep|Bash|Task",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-cli-reminder.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-staleness-detector.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/stop-reindex-reminder.ts",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
