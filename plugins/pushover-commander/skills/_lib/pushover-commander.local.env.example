# pushover-commander — PRIVATE config TEMPLATE (no real values here; safe to commit).
#
# Copy this to your private, gitignored location and fill in YOUR values:
#     mkdir -p ~/.claude/pushover-commander.private
#     cp pushover-commander.local.env.example ~/.claude/pushover-commander.private/pushover-commander.local.env
#     chmod 600 ~/.claude/pushover-commander.private/pushover-commander.local.env
# (Override the location with PUSHOVER_COMMANDER_PRIVATE_CONFIG.)
# `_lib/resolve_pushover_secret.sh` sources this file automatically.
#
# This is the dotfiles model: the cc-skills plugin is public + generic; every
# operator's account, item, and tokens stay private under their own ~/.claude.

# ── 1Password item holding YOUR Pushover secrets ───────────────────────────────
# Create a 1Password item with these fields, then point the two vars below at it:
#   login_email      your pushover.net account email   (for the headless web-control login)
#   login_password   your pushover.net account password
#   (A STANDARD 1Password "Login" item works as-is: login_email auto-aliases to the
#    item's `username` field, and login_password to `password` — no custom fields needed.)
#   user_key         your Pushover user key
#   device           (optional) a default device name
#   api_token_main   (optional) production app token used by `send-notification --app main`
#   api_token_test   (optional) test app token used by `send-notification` (default)
export PUSHOVER_OP_VAULT="Your 1Password Vault"
export PUSHOVER_OP_ITEM="Your Pushover Item Name Or ID"

# ── optional overrides (sane defaults shown) ───────────────────────────────────
# macOS Keychain service name used as a fallback when 1Password is unavailable:
# export PUSHOVER_KEYCHAIN_SERVICE="pushover-commander"
# An `op` Service Account token file (scriptable reads, no Touch ID prompt):
# export PUSHOVER_OP_SA_TOKEN_FILE="$HOME/.claude/.secrets/op-service-account-token"
# Where send-notification appends its UUID-keyed JSONL audit trail:
# export PUSHOVER_AUDIT_PATH="$HOME/.local/state/pushover/po-audit.jsonl"
# Monospace TTF for render-incident-report-image (macOS default is JetBrains Mono):
# export PUSHOVER_RENDER_FONT_PATH="$HOME/Library/Fonts/JetBrainsMonoNerdFontMono-Regular.ttf"
