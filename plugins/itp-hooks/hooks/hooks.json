{
  "description": "ITP workflow enforcement - implementation standards, documentation coupling, fake data guard, code correctness, SR&ED commit validation, process storm prevention, Vale terminology enforcement, GLOSSARY.md bidirectional sync, file size bloat prevention",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-subprocess-stdin-inlet-guard.ts",
            "timeout": 5000,
            "description": "Bash subprocess stdin inlet guard — pre-disconnects stdin via < /dev/null wrap on Bash invocations (iter-63 narrowed matcher from `*` to `Bash`: only Bash spawns the subprocess class with TTY-contention risk; non-Bash tools (Read/Glob/Grep/Edit/Write/mcp__*) save ~12-17ms cold-start each)"
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-process-storm-guard.mjs",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-cwd-deletion-guard.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-gpu-optimization-guard.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-mise-hygiene-guard.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-pyi-stub-guard.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-edit-time-orchestrator-combining-multiple-subhooks-into-single-bun-process-iter66-precedent.ts",
            "timeout": 15000,
            "description": "Iter-84/85/86 in-process orchestrator: combines multiple Write|Edit subhooks into ONE bun process, amortizing the ~44ms bun cold-start (measured iter-80) across the registry instead of paying it N times. Per iter-81 ranker, final-state savings = (8-1) × 44 = 308ms per Write|Edit. Inlined subhooks (registry-order, lightest-first deny-wins): version-guard, hoisted-deps-guard, file-size-guard. Iter-87+ migrates remaining Write|Edit subhooks (gpu-optimization, mise-hygiene, pyi-stub, native-binary, vale-claude-md) one per iter. Belt-and-suspenders deny+ask defense per GH #37210 / iter-78 (stdout JSON + stderr + exitCode=2 with stdout-drain-await per iter-85 audit hardening). Process-level unhandledRejection fail-open handler per iter-85 audit. Subhook contract violations gated preventively by iter-86 audit task (audit-pretooluse-orchestrator-subhook-contract-violations-static-check-...sh)."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-native-binary-guard.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-vale-claude-md-guard.ts",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-iter78-layer3-stripped-path-edit-time-guard.ts",
            "timeout": 5000,
            "description": "Iter-78 edit-time companion to iter-77 release-time Check 4k — blocks edits that introduce references to ${CLAUDE_PLUGIN_ROOT}/<segment>/ where <segment> is NOT in the cache-populator allowlist {hooks, skills, commands, agents, plugin.json}; belt-and-suspenders defense (stdout JSON deny + stderr diagnostic + exit 2) per GitHub #37210"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-large-file-read-guard.ts",
            "timeout": 5000,
            "description": "Warns Claude when reading files >2000 lines without offset/limit"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-uv-enforcement-guard.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-pth-contamination-guard.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-pueue-local-guard.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-cargo-tty-guard.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-parquet-duckdb-nudge.ts",
            "timeout": 5000,
            "description": "Nudge toward DuckDB for Parquet content analysis (soft, warn+allow)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-pueue-wrap-guard.ts",
            "timeout": 5000,
            "description": "Pueue auto-wrap + OP_SERVICE_ACCOUNT_TOKEN injection — MUST be LAST PreToolUse entry (mitigates GitHub #15897 multi-hook updatedInput aggregation bug)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-subprocess-orphan-cleanup.ts",
            "timeout": 5000,
            "description": "Bash subprocess orphan cleanup — removes zombie/TTY-holding orphans spawned by Bash invocations (iter-64 narrowed matcher from `*` to `Bash`: only Bash spawns subprocesses that can orphan; Read/Glob/Grep/Edit/Write are in-process; async:true from iter-57 already prevented user-latency cost, but matcher narrowing also eliminates ~12-17ms CPU+battery waste per non-Bash call)",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-reminder.ts",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/code-correctness-guard.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-vale-claude-md.ts",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-glossary-sync.ts",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-terminology-sync.ts",
            "timeout": 8000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-readme-pypi-links.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-ssot-principles.ts",
            "timeout": 3000,
            "description": "SSoT/DI principles reminder with ast-grep detection (once per session)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-memory-efficiency-reminder.ts",
            "timeout": 3000,
            "description": "Memory efficiency reminder - zero-copy, pre-allocate, cache locality, lazy eval (once per session)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-ty-type-check.ts",
            "timeout": 5000,
            "description": "ty type checker - runs on every .py file edit (4.7ms incremental)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-tsgo-type-check.ts",
            "timeout": 5000,
            "description": "tsgo type checker - runs on every .ts/.tsx file edit (~170ms project check)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-oxlint-check.ts",
            "timeout": 5000,
            "description": "oxlint correctness checker - runs on every .ts/.tsx/.js/.jsx file edit (~50ms)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-biome-lint.ts",
            "timeout": 5000,
            "description": "biome lint - complementary JS/TS checks (useConst, noDoubleEquals, node: protocol)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/hooks/stop-orchestrator.ts",
            "timeout": 65000,
            "asyncRewake": true,
            "rewakeSummary": "Loop stall detected — rewaking to schedule waker",
            "description": "Stop-hook orchestrator: sequentially runs the 5 itp-hooks Stop hooks (subprocess-cleanup, error-summary, ty-check, markdown-lint, loop-stall-guard) with per-subhook timeout + crash isolation. Replaces 5 entries in the Stop hook display list with 1. asyncRewake on exit 2 propagates from loop-stall-guard."
          }
        ]
      }
    ]
  }
}
